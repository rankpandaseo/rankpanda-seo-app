# Database
# PostgreSQL connection string (local dev uses docker-compose postgres:5432)
DATABASE_URL=postgresql://rankpanda:rankpanda@localhost:5432/rankpanda_dev

# Session (CRITICAL: 32+ random characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET

# Node environment
NODE_ENV=development

# Server port (local dev runs on 3000)
PORT=3000

# Optional: Shopify (for Phase 2)
# SHOPIFY_API_KEY=test_key
# SHOPIFY_API_SECRET=test_secret
# SHOPIFY_APP_URL=http://localhost:3000
