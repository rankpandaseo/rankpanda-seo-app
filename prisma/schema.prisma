generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String   // bcryptjs hash
  role          String   @default("user")       // "admin" | "user"
  status        String   @default("pending")    // "pending" | "active" | "banned"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projetos      Projeto[]
  sessions      Session[]
  approvalLogs  UserApprovalLog[]
}

model Projeto {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  shopName  String

  businessContext     String?  @db.Text
  businessKeywords    String?  @db.Text
  merchantCenterCategories String? @db.Text
  voiceTone           String?  @db.Text

  ga4PropertyId       String?
  ga4Credentials      String?  @db.Text

  gscPropertyUrl      String?
  gscCredentials      String?  @db.Text

  bingWebmasterToken  String?

  seRankingApiKey     String?
  seRankingProjectId  String?

  shopifyAccessToken  String?  @db.Text
  shopifyRefreshToken String?  @db.Text

  setupCompleted      Boolean  @default(false)
  currentSetupStep    Int      @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  keywords            KeywordResearch[]

  @@unique([userId, shopName])
  @@index([userId])
}

model KeywordResearch {
  id         String   @id @default(cuid())
  projectoId String
  projeto    Projeto  @relation(fields: [projectoId], references: [id], onDelete: Cascade)

  keyword    String
  searchVolume Int?
  intent     String?
  status     String   @default("active")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectoId])
  @@unique([projectoId, keyword])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model UserApprovalLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "approved" | "rejected" | "banned"
  approvedBy String  // admin userId
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
}
