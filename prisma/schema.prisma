generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KeywordResearch {
  id           String   @id @default(cuid())
  projectoId   String
  keyword      String
  searchVolume Int?
  intent       String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  Projeto      Projeto  @relation(fields: [projectoId], references: [id], onDelete: Cascade)

  @@unique([projectoId, keyword])
  @@index([projectoId])
}

model Projeto {
  id                       String            @id @default(cuid())
  userId                   String
  shopName                 String
  shopDomain               String?
  businessContext          String?
  businessKeywords         String?
  merchantCenterCategories String?
  voiceTone                String?
  ga4PropertyId            String?
  ga4Credentials           String?
  gscPropertyUrl           String?
  gscCredentials           String?
  bingWebmasterToken       String?
  seRankingApiKey          String?
  seRankingProjectId       String?
  shopifyAccessToken       String?
  shopifyRefreshToken      String?
  setupCompleted           Boolean           @default(false)
  currentSetupStep         Int               @default(0)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime
  KeywordResearch          KeywordResearch[]
  User                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopName])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  password        String
  role            String            @default("user")
  status          String            @default("pending")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  Projeto         Projeto[]
  Session         Session[]
  UserApprovalLog UserApprovalLog[]
}

model UserApprovalLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  approvedBy String
  reason     String?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
